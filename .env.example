# ⚠️ REFERENCE ONLY — this is the manifest of env vars this app needs.
# Use it to create the GitHub Secrets (DEV_/PROD_ prefixed) for deployment.
#
# For LOCAL DEVELOPMENT do NOT copy this to .env. Secrets come from 1Password:
#   op run --env-file=.env.tpl -- npm run dev
# (.env.tpl resolves these vars from the Innovation vault at runtime.)

# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Private (server-side only)
SUPABASE_SECRET_KEY=your-secret-key

# App
ORIGIN=http://localhost:3000
